# Copy to .env and fill in your key
OPENAI_API_KEY=sk-...

# Two-tier model split (Day 2.5+)
OPENAI_MODEL_ASSESS=gpt-5.4         # compliance judgment (precision)
OPENAI_MODEL_INGEST=gpt-5.4-mini    # vision claim extraction (cost)

# Legacy single-model knobs — honored as fallback if the split vars are unset.
# OPENAI_MODEL=gpt-5.4
# OPENAI_MODEL_MINI=gpt-5.4-mini

# Optional: Chroma persistence dir (defaults to ./.chroma)
CHROMA_DIR=.chroma

# Optional: run without real OpenAI calls (uses canned fixture responses) — dev convenience
COMPLIANCELENS_MOCK_LLM=0
