# ----------------------------------------------------------------------------
# Secrets — never commit
# ----------------------------------------------------------------------------
**/.env
**/.env.local
**/.env.*.local

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
**/__pycache__/
*.pyc
*.pyo
*.pyd
**/.venv/
**/venv/
**/.pytest_cache/
**/.mypy_cache/
*.egg-info/

# ----------------------------------------------------------------------------
# Node / Next.js
# ----------------------------------------------------------------------------
**/node_modules/
**/.next/
**/out/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Runtime artifacts (regenerated by the app)
# ----------------------------------------------------------------------------
backend/.chroma/
backend/.checkpoints.sqlite
backend/.checkpoints.sqlite-journal
backend/.checkpoints.sqlite-shm
backend/.checkpoints.sqlite-wal
backend/*.sqlite
backend/*.sqlite-*

# User uploads — may contain third-party artwork; regenerated at runtime.
backend/data/uploads/

# Generated reports — produced by run_demo.py / API; not source.
backend/data/samples/*.report.md

# ----------------------------------------------------------------------------
# Working docs — Claude Code 킥오프/기획/아키텍처. 로컬에는 유지하되 공개 X.
# ----------------------------------------------------------------------------
ComplianceLens_기획.md
ComplianceLens_아키텍처.md
ComplianceLens_프롬프트_README.md

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
