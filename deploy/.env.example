# EC2 호스트 ~/JB_Hack/.env 로 복사해서 채울 것.
# (이 파일은 템플릿 — docker compose는 프로젝트 루트의 .env 를 자동 로드함)
#
#   cd ~/JB_Hack
#   cp deploy/.env.example .env
#   nano .env

OPENAI_API_KEY=sk-...
OPENAI_MODEL_ASSESS=gpt-5.4
OPENAI_MODEL_INGEST=gpt-5.4-mini

# 데모 중 OpenAI 비용/장애 회피 시 1로
COMPLIANCELENS_MOCK_LLM=0

# 같은 origin 배포라 보통 필요 없음. CloudFront 분리하거나 외부에서 cross-origin 호출이
# 들어오면 그 origin을 콤마로 추가:
#   ALLOWED_ORIGINS=https://d1abcdef.cloudfront.net,https://my-domain.com
ALLOWED_ORIGINS=http://localhost
